# Server config
# HOST: the server has no authentication — keep it on localhost unless you
# understand the risk. Set to 0.0.0.0 to allow access from other devices.
HOST=127.0.0.1
PORT=8420

# Maximum concurrent sessions (default: 8)
MAX_SESSIONS=8

# Idle session timeout in seconds (default: 0 = disabled)
IDLE_TIMEOUT=0

# Suppress auto-opening browser (set to 1 to disable)
NO_BROWSER=0

# OpenRouter API key (optional) — enables OpenRouter-routed sessions.
# Create one at https://openrouter.ai/settings/keys and load credits.
# Leave empty to disable; the key never leaves the server.
OPENROUTER_API_KEY=
