{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Claude Cockpit",
  "version": "0.2.3-alpha",
  "identifier": "com.claude-cockpit.app",
  "build": {
    "devUrl": "http://localhost:5174",
    "frontendDist": "http://localhost:8420",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Claude Cockpit",
        "width": 1600,
        "height": 1000,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ws://localhost:8420 wss://localhost:8420 http://localhost:8420 https://github.com https://api.github.com ipc://localhost; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; font-src 'self' data:; img-src 'self' data: blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/cockpit-server"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerHooks": "installer-hooks.nsh"
      }
    },
    "createUpdaterArtifacts": "v1Compatible"
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/NovemberFalls/claude-cockpit/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU1MUMwQkQzQ0Q4NTJGQjIKUldTeUw0WE4wd3NjVlFyYmx3ZGJQa2RlWmFnTDM2Y1N2Z2NyWlRYOTN2T3dST3l0dUR3U2VkbS8K"
    }
  }
}
