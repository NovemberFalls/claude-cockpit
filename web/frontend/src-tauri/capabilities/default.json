{
  "identifier": "default",
  "description": "Default capabilities for Claude Cockpit",
  "windows": ["main"],
  "remote": {
    "urls": ["http://localhost:8420/*"]
  },
  "permissions": [
    "core:default",
    "shell:allow-execute",
    "shell:allow-spawn",
    "shell:allow-open",
    "updater:default",
    "process:allow-restart"
  ]
}
