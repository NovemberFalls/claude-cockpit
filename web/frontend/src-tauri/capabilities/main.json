{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main",
  "description": "Main window capabilities",
  "windows": ["main", "popout-*"],
  "permissions": [
    "core:default",
    "core:webview:allow-create-webview-window",
    "core:window:default",
    "core:window:allow-set-title",
    "core:window:allow-close",
    "core:event:default"
  ]
}
