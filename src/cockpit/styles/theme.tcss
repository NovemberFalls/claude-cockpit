/* Claude Cockpit — Dark theme inspired by Nord/Tokyo Night */

$bg: #1a1b26;
$bg-surface: #24283b;
$bg-elevated: #292e42;
$bg-highlight: #343b58;
$fg: #c0caf5;
$fg-dim: #565f89;
$fg-muted: #737aa2;
$accent: #7aa2f7;
$accent-warm: #ff9e64;
$green: #9ece6a;
$red: #f7768e;
$yellow: #e0af68;
$purple: #bb9af7;
$cyan: #7dcfff;
$border: #3b4261;

Screen {
    background: $bg;
    color: $fg;
}

/* Header */
Header {
    background: $bg-surface;
    color: $accent;
    dock: top;
    height: 1;
}

/* Footer */
Footer {
    background: $bg-surface;
    color: $fg-dim;
}

/* Sidebar */
#sidebar {
    width: 28;
    background: $bg-surface;
    border-right: solid $border;
    dock: left;
    padding: 0;
}

#sidebar-title {
    background: $bg-elevated;
    color: $accent;
    text-style: bold;
    padding: 0 1;
    height: 1;
    width: 100%;
}

#session-tree {
    background: $bg-surface;
    padding: 0 1;
    scrollbar-size: 1 1;
}

#session-tree > .tree--cursor {
    background: $bg-highlight;
    color: $accent;
}

#session-tree > .tree--label {
    color: $fg;
}

/* Main content area */
#main-content {
    background: $bg;
}

/* Tabbed content */
TabbedContent {
    background: $bg;
}

ContentSwitcher {
    background: $bg;
}

TabPane {
    background: $bg;
    padding: 0;
}

Tabs {
    background: $bg-surface;
    dock: top;
    height: 3;
}

Tab {
    background: $bg-surface;
    color: $fg-dim;
    padding: 0 2;
}

Tab.-active {
    background: $bg;
    color: $accent;
    text-style: bold;
}

Tab:hover {
    background: $bg-elevated;
    color: $fg;
}

Underline {
    color: $accent;
}

/* Chat display */
.chat-log {
    background: $bg;
    padding: 0 1;
    scrollbar-size: 1 1;
    border: none;
}

/* Input area */
#input-area {
    dock: bottom;
    height: 3;
    background: $bg-surface;
    border-top: solid $border;
    padding: 0 1;
}

#prompt-input {
    background: $bg-elevated;
    color: $fg;
    border: tall $border;
    height: 1;
    margin: 0 1 0 0;
}

#prompt-input:focus {
    border: tall $accent;
}

#send-btn {
    background: $accent;
    color: $bg;
    min-width: 8;
    height: 1;
    margin: 0;
    text-style: bold;
    border: none;
}

#send-btn:hover {
    background: $cyan;
}

#send-btn.-disabled {
    background: $bg-highlight;
    color: $fg-dim;
}

/* Token bar */
#token-bar {
    dock: bottom;
    height: 1;
    background: $bg-elevated;
    color: $fg-dim;
    padding: 0 1;
    border-top: solid $border;
}

.token-stat {
    color: $fg-muted;
}

.token-value {
    color: $fg;
    text-style: bold;
}

.cost-value {
    color: $green;
    text-style: bold;
}

/* Session pane */
.session-pane {
    background: $bg;
    height: 100%;
}

/* Message styles */
.user-msg {
    background: $bg-elevated;
    color: $fg;
    padding: 0 1;
    margin: 0 0 0 4;
}

.assistant-msg {
    color: $fg;
    padding: 0 1;
    margin: 0 4 0 0;
}

.tool-msg {
    color: $fg-dim;
    padding: 0 1;
    text-style: italic;
}

.system-msg {
    color: $yellow;
    padding: 0 1;
    text-style: italic;
}

/* Welcome screen */
#welcome {
    align: center middle;
    background: $bg;
}

#welcome-box {
    width: 60;
    height: auto;
    background: $bg-surface;
    border: round $border;
    padding: 2 4;
}

#welcome-title {
    text-align: center;
    color: $accent;
    text-style: bold;
    width: 100%;
    margin-bottom: 1;
}

#welcome-subtitle {
    text-align: center;
    color: $fg-dim;
    width: 100%;
    margin-bottom: 1;
}

.welcome-key {
    color: $accent;
    text-style: bold;
}

.welcome-desc {
    color: $fg-dim;
}

/* Scrollbars */
Scrollbar {
    background: $bg-surface;
    color: $bg-highlight;
}

/* New session dialog */
#new-session-dialog {
    align: center middle;
}

#dialog-box {
    width: 50;
    height: auto;
    background: $bg-surface;
    border: round $accent;
    padding: 1 2;
}

#dialog-title {
    text-align: center;
    color: $accent;
    text-style: bold;
    width: 100%;
    margin-bottom: 1;
}

.dialog-label {
    color: $fg-dim;
    margin-top: 1;
}

.dialog-input {
    background: $bg-elevated;
    color: $fg;
    border: tall $border;
    margin-bottom: 0;
}

.dialog-input:focus {
    border: tall $accent;
}

#dialog-buttons {
    margin-top: 1;
    align: center middle;
    height: 3;
}

.dialog-btn {
    min-width: 12;
    margin: 0 1;
}

/* Model selector */
#model-select {
    background: $bg-elevated;
    color: $fg;
    border: tall $border;
}

/* Container header */
.container-label {
    color: $purple;
    text-style: bold;
}

/* Status indicators */
.status-idle {
    color: $green;
}

.status-running {
    color: $yellow;
}

.status-error {
    color: $red;
}

/* Loading spinner area */
.loading-indicator {
    color: $accent;
    text-align: center;
}
